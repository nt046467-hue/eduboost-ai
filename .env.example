# Google AdSense Configuration (Optional - defaults already set)
# These variables are OPTIONAL and already configured in the code
# Copy this to .env if you want to customize

# ✅ Publisher ID - Your Google AdSense Publisher ID
VITE_ADSENSE_PUBLISHER_ID=ca-pub-3896962422851508

# ✅ Enable/Disable Ads
VITE_ADS_ENABLED=true

# ✅ Gentle Ad Settings
# Maximum ads per page (Google recommends max 3)
VITE_AD_DENSITY_MAX=3

# Minimum spacing between ads in pixels (300px recommended)
VITE_AD_MIN_SPACING=300

# Prevent aggressive ad refresh (keep false for gentle ads)
VITE_AD_AUTO_REFRESH=false

# Auto Ads enabled by default
VITE_AUTO_ADS_ENABLED=true

# Optional: Development settings
NODE_ENV=production

# Optional: Netlify deployment branch (usually 'main' for production)
NETLIFY_SITE_ID=your-netlify-site-id  # Fill this in after deploying to Netlify
